#: include/abilities/nexter-bulk-image-optimizer.php:20
msgid "Get Bulk Image Optimizer Status"
msgstr ""

#: include/abilities/nexter-bulk-image-optimizer.php:21
msgid "Returns Nexter Bulk Image Optimizer stats (totals, savings, monthly usage) and the next batch of unoptimized attachments — the same data shown on Media → Bulk Images."
msgstr ""

#: include/abilities/nexter-bulk-image-optimizer.php:59
msgid "Bulk Optimize Images"
msgstr ""

#: include/abilities/nexter-bulk-image-optimizer.php:60
msgid "Optimizes one or more attachments using the configured Nexter Image Optimization settings. Same effect as clicking Start Bulk Optimisation on Media → Bulk Images."
msgstr ""

#: include/abilities/nexter-bulk-image-optimizer.php:98
#: dashboard/build/index.js:9
msgid "Restore Original Images"
msgstr ""

#: include/abilities/nexter-bulk-image-optimizer.php:99
msgid "Restores all images that were optimized by Nexter back to their original files from backup, and clears optimization metadata."
msgstr ""

#: include/abilities/nexter-create-snippet.php:13
msgid "Create Code Snippet"
msgstr ""

#: include/abilities/nexter-create-snippet.php:14
msgid "Creates a new Nexter Extension code snippet. Supports PHP, CSS, JavaScript, and HTML snippet types with configurable insertion locations, conditions, scheduling, and display rules."
msgstr ""

#: include/abilities/nexter-create-template.php:13
msgid "Create Theme Builder Template"
msgstr ""

#: include/abilities/nexter-create-template.php:14
msgid "Creates a new Nexter Extension Theme Builder template (header, footer, singular, archives, 404, hooks, breadcrumb, or section) with display rules and type-specific settings."
msgstr ""

#: include/abilities/nexter-custom-fonts.php:9
msgid "Get Custom Fonts Settings"
msgstr ""

#: include/abilities/nexter-custom-fonts.php:10
msgid "Retrieves uploaded custom fonts configuration including font names, file IDs, and weight variations."
msgstr ""

#: include/abilities/nexter-custom-fonts.php:27
msgid "Update Custom Fonts Settings"
msgstr ""

#: include/abilities/nexter-custom-fonts.php:28
msgid "Updates custom font upload feature: enable/disable and configure font families with weight variations."
msgstr ""

#: include/abilities/nexter-delete-snippet.php:13
msgid "Delete Code Snippet"
msgstr ""

#: include/abilities/nexter-delete-snippet.php:14
msgid "Permanently deletes a Nexter Extension code snippet by ID. This removes the snippet file from the filesystem and updates the index. This action cannot be undone."
msgstr ""

#: include/abilities/nexter-delete-template.php:13
msgid "Delete Theme Builder Template"
msgstr ""

#: include/abilities/nexter-delete-template.php:14
msgid "Permanently deletes a Nexter Theme Builder template by post ID. This action cannot be undone."
msgstr ""

#: include/abilities/nexter-get-snippet.php:13
msgid "Get Code Snippet"
msgstr ""

#: include/abilities/nexter-get-snippet.php:14
msgid "Retrieves a single Nexter Extension code snippet by ID, including full source code, metadata, conditions, display rules, and all settings. Use nexter/list-snippets first to discover available snippet IDs."
msgstr ""

#: include/abilities/nexter-get-template.php:13
msgid "Get Theme Builder Template"
msgstr ""

#: include/abilities/nexter-get-template.php:14
msgid "Retrieves a single Nexter Theme Builder template by ID with all settings including display rules, conditions, type-specific options, and edit URL."
msgstr ""

#: include/abilities/nexter-image-optimization.php:9
msgid "Get Image Optimization Settings"
msgstr ""

#: include/abilities/nexter-image-optimization.php:10
msgid "Retrieves Nexter Extension image optimization/compression settings including format, quality, resize, and exclusion rules."
msgstr ""

#: include/abilities/nexter-image-optimization.php:31
msgid "Update Image Optimization Settings"
msgstr ""

#: include/abilities/nexter-image-optimization.php:32
msgid "Updates Nexter Extension image optimization settings. Only provided fields are changed."
msgstr ""

#: include/abilities/nexter-list-extensions.php:13
msgid "List Nexter Extensions"
msgstr ""

#: include/abilities/nexter-list-extensions.php:14
msgid "Lists all available Nexter Extension modules with their activation status, showing which features are enabled or disabled."
msgstr ""

#: include/abilities/nexter-list-snippets.php:13
msgid "List Code Snippets"
msgstr ""

#: include/abilities/nexter-list-snippets.php:14
msgid "Lists all Nexter Extension code snippets with metadata including name, type (php/css/javascript/html), status (active/inactive), tags, description, insertion location, and priority. Returns snippets sorted newest-first."
msgstr ""

#: include/abilities/nexter-list-templates.php:13
msgid "List Theme Builder Templates"
msgstr ""

#: include/abilities/nexter-list-templates.php:14
msgid "Lists all Nexter Extension Theme Builder templates (headers, footers, singular, archives, 404, hooks, breadcrumbs) with their type, status, and display rules."
msgstr ""

#: include/abilities/nexter-performance-settings.php:9
msgid "Get Performance Settings"
msgstr ""

#: include/abilities/nexter-performance-settings.php:10
msgid "Retrieves all Nexter performance settings including heartbeat control, lazy loading, preloading, minification, emoji/embed disabling, and more."
msgstr ""

#: include/abilities/nexter-performance-settings.php:31
msgid "Update Performance Settings"
msgstr ""

#: include/abilities/nexter-performance-settings.php:32
msgid "Updates Nexter performance settings. Can enable/disable features and change their values. Only provided features are modified."
msgstr ""

#: include/abilities/nexter-security-settings.php:9
msgid "Get Nexter Security Settings"
msgstr ""

#: include/abilities/nexter-security-settings.php:10
msgid "Retrieve all security settings. Returns every configured security feature with its enabled status and values."
msgstr ""

#: include/abilities/nexter-security-settings.php:31
msgid "Update Nexter Security Settings"
msgstr ""

#: include/abilities/nexter-security-settings.php:32
msgid "Update a specific security feature. Set enabled to toggle, and values to update configuration."
msgstr ""

#: include/abilities/nexter-smtp-settings.php:9
msgid "Get SMTP Email Settings"
msgstr ""

#: include/abilities/nexter-smtp-settings.php:10
msgid "Retrieves Nexter SMTP email configuration including type (Gmail/Custom), host, port, encryption, and from address."
msgstr ""

#: include/abilities/nexter-smtp-settings.php:27
msgid "Update SMTP Email Settings"
msgstr ""

#: include/abilities/nexter-smtp-settings.php:28
msgid "Updates Nexter SMTP email configuration. Supports Gmail OAuth and Custom SMTP with host/port/encryption/auth."
msgstr ""

#: include/abilities/nexter-toggle-extension.php:13
msgid "Toggle Nexter Extension"
msgstr ""

#: include/abilities/nexter-toggle-extension.php:14
msgid "Enables or disables a specific Nexter Extension module by key name. Use nexter/list-extensions to see available module keys."
msgstr ""

#: include/abilities/nexter-toggle-snippet.php:13
msgid "Toggle Code Snippet"
msgstr ""

#: include/abilities/nexter-toggle-snippet.php:14
msgid "Enables or disables a Nexter Extension code snippet by toggling its activation status. Can explicitly set active/inactive or toggle the current state."
msgstr ""

#: include/abilities/nexter-toggle-template.php:13
msgid "Toggle Theme Builder Template"
msgstr ""

#: include/abilities/nexter-toggle-template.php:14
msgid "Enables or disables a Nexter Theme Builder template. Can explicitly set active/inactive or toggle current state."
msgstr ""

#: include/abilities/nexter-update-snippet.php:13
msgid "Update Code Snippet"
msgstr ""

#: include/abilities/nexter-update-snippet.php:14
msgid "Updates an existing Nexter Extension code snippet. You can update the code, name, description, tags, type, location, conditions, and all other settings. Only provided fields are updated — omitted fields keep their current values."
msgstr ""

#: include/abilities/nexter-update-template.php:13
msgid "Update Theme Builder Template"
msgstr ""

#: include/abilities/nexter-update-template.php:14
msgid "Updates an existing Nexter Theme Builder template settings including title, display rules, and type-specific options. Only provided fields are updated."
msgstr ""

